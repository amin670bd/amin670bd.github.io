/* ===== FONT FACE: Outfit (Aptos Display alternative) ===== */
@font-face {
  font-family: 'Outfit';
  font-style: normal;
  font-weight: 400 800;
  font-display: swap;
  src: url(assets/fonts/outfit-latin.woff2) format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
@font-face {
  font-family: 'Outfit';
  font-style: normal;
  font-weight: 400 800;
  font-display: swap;
  src: url(assets/fonts/outfit-latin-ext.woff2) format('woff2');
  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
}

/* ===== CSS CUSTOM PROPERTIES ===== */
:root {
  --primary: #0891b2;
  --primary-dark: #0369a1;
  --primary-light: #67e8f9;
  --teal: #059669;
  --gradient-deep: #1e40af;
  --gradient-teal: #0d9488;
  --gradient-green: #059669;
  --bg: linear-gradient(135deg, #f0fdf4, #f0fdfa, #ecfdf5);
  --bg-card: rgba(255,255,255,0.85);
  --text: #1e293b;
  --text-heading: #020617;
  --text-muted: #475569;
  --text-label: #64748b;
  --border: rgba(0,0,0,0.08);
  --sidebar-bg: rgba(255,255,255,0.88);
  --sidebar-text: #475569;
  --sidebar-heading: #020617;
  --sidebar-divider: rgba(148,163,184,0.3);
  --nav-bg: rgba(255,255,255,0.9);
  --shadow: 0 1px 3px rgba(0,0,0,0.06);
  --shadow-lg: 0 10px 25px rgba(0,0,0,0.08);
  --shadow-glow: 0 0 20px rgba(20,184,166,0.15);
  --radius: 16px;
  --radius-sm: 10px;
  --accent-amber: #f59e0b;
  --accent-emerald: #10b981;
  --glass-bg: rgba(255,255,255,0.7);
  --glass-border: rgba(255,255,255,0.25);
  --glass-shadow: 0 8px 32px rgba(0,0,0,0.06);
  --glass-blur: 12px;
  --toggle-bg: rgba(0,0,0,0.04);
  --toggle-border: rgba(0,0,0,0.08);
}

.dark {
  --bg: linear-gradient(135deg, #022c22, #021a17, #022c22);
  --bg-card: rgba(5,46,33,0.55);
  --text: #cbd5e1;
  --text-heading: #e2e8f0;
  --text-muted: #94a3b8;
  --text-label: #a0aec0;
  --border: rgba(45,212,191,0.12);
  --primary: #2dd4bf;
  --primary-dark: #14b8a6;
  --primary-light: #5eead4;
  --teal: #10b981;
  --gradient-deep: #065f46;
  --gradient-teal: #0d9488;
  --gradient-green: #10b981;
  --sidebar-bg: rgba(5,46,33,0.92);
  --sidebar-text: #e2e8f0;
  --sidebar-heading: #ffffff;
  --sidebar-divider: rgba(45,212,191,0.2);
  --nav-bg: rgba(5,46,33,0.9);
  --shadow: 0 1px 3px rgba(0,0,0,0.3);
  --shadow-lg: 0 10px 25px rgba(0,0,0,0.4);
  --shadow-glow: 0 0 30px rgba(20,184,166,0.25);
  --glass-bg: rgba(5,46,33,0.5);
  --glass-border: rgba(255,255,255,0.06);
  --glass-shadow: 0 8px 32px rgba(0,0,0,0.3);
  --glass-blur: 12px;
  --toggle-bg: rgba(255,255,255,0.06);
  --toggle-border: rgba(255,255,255,0.10);
}

/* ===== BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Outfit', 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 15px;
  background: var(--bg);
  background-size: 200% 200%;
  animation: gradient-shift 10s ease infinite;
  color: var(--text);
  line-height: 1.65;
  transition: background 0.3s, color 0.3s;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
h1, h2, h3, h4, h5, h6 {
  color: var(--text-heading);
  line-height: 1.3;
}
::selection { background: #f59e0b; color: #000; }
::-moz-selection { background: #f59e0b; color: #000; }
a { color: var(--primary); text-decoration: none; transition: color 0.2s; }
a:hover { color: var(--primary-dark); }
img { max-width: 100%; height: auto; }

/* Custom Scrollbar */
body::-webkit-scrollbar { width: 6px; }
body::-webkit-scrollbar-track { background: transparent; }
body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
body::-webkit-scrollbar-thumb:hover { background: var(--primary); }
* { scrollbar-width: thin; scrollbar-color: var(--border) transparent; }

/* ===== SIDEBAR ===== */
.sidebar {
  width: 300px;
  height: 100vh;
  position: fixed;
  left: 0;
  top: 0;
  background: var(--sidebar-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  color: var(--sidebar-text);
  z-index: 40;
  transition: background 0.3s;
  display: flex;
  flex-direction: column;
}
.sidebar-scroll {
  flex: 1;
  overflow-y: auto;
}
.sidebar-scroll::-webkit-scrollbar { width: 4px; }
.sidebar-scroll::-webkit-scrollbar-track { background: transparent; }
.sidebar-scroll::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }

.sidebar h2.text-xl { font-size: 1.1rem; }
.sidebar p.text-lg { font-size: 0.95rem; }
.sidebar .sidebar-scroll .font-medium { font-size: 0.85rem; }
.sidebar .nav-link span { font-size: 0.9rem; }
.sidebar .text-lg.flex.items-center { font-size: 0.9rem; }

.nav-link {
  color: var(--sidebar-text);
  transition: background 0.2s, color 0.2s;
}
.nav-link:hover {
  background: rgba(20,184,166,0.08);
  color: var(--sidebar-heading);
}
.nav-link-active {
  background: rgba(20,184,166,0.12) !important;
  color: var(--sidebar-heading) !important;
}

/* ===== MAIN CONTENT ===== */
.main-content {
  margin-left: 300px;
  min-height: 100vh;
  padding-top: 0;
}

/* ===== MOBILE NAV ===== */
.mobile-nav {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background: var(--nav-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  z-index: 50;
  transition: background 0.3s;
}
.download-cv-short { display: inline; }
.download-cv-full { display: none; }
@media (min-width: 640px) {
  .download-cv-short { display: none; }
  .download-cv-full { display: inline; }
}

/* ===== HERO ===== */
.hero-section {
  padding: 100px 60px 80px;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(20,184,166,0.07) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 50%, rgba(16,185,129,0.05) 0%, transparent 50%);
  position: relative;
}
.hero-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 30% 20%, rgba(20,184,166,0.03) 0%, transparent 50%),
    radial-gradient(circle at 70% 80%, rgba(16,185,129,0.02) 0%, transparent 50%);
  pointer-events: none;
}
.hero-title {
  font-size: 2.6rem;
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.02em;
}
.hero-stats { display: flex; gap: 2rem; flex-wrap: wrap; }
.hero-stat-value {
  font-size: 1.7rem;
  font-weight: 800;
  color: var(--text-heading);
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ===== SECTION ===== */
.section {
  padding: 80px 60px;
  border-bottom: 1px solid var(--border);
  transition: background 0.3s, border-color 0.3s;
}
.section:last-child { border-bottom: none; }
.section-tag {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--primary);
  margin-bottom: 8px;
}
.section-title {
  font-size: 1.75rem;
  font-weight: 800;
  margin-bottom: 2rem;
  letter-spacing: -0.01em;
}

/* ===== CARDS ===== */
.card-glass {
  background: var(--bg-card);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem;
  transition: all 0.3s ease;
}
.card-glass:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.card-glass-alt {
  background: var(--sidebar-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: var(--sidebar-text);
  border: 1px solid var(--sidebar-divider);
  border-radius: var(--radius);
  padding: 1.5rem;
}
.card-glass-alt h3, .card-glass-alt h4 { color: var(--sidebar-heading); }

.card-glass--glass {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur));
  -webkit-backdrop-filter: blur(var(--glass-blur));
  border: 1px solid var(--glass-border);
  box-shadow: var(--glass-shadow);
}

/* ===== SKILL PILLS ===== */
.skill-pill {
  display: inline-block;
  padding: 6px 16px;
  margin: 4px;
  font-size: 0.85rem;
  font-weight: 600;
  border-radius: 999px;
  background: rgba(20,184,166,0.08);
  color: var(--primary);
  border: 1px solid rgba(20,184,166,0.2);
  position: relative;
  overflow: hidden;
  z-index: 1;
  cursor: default;
  transition: all 0.25s ease;
}
.skill-pill::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  opacity: 0;
  z-index: -1;
  transition: opacity 0.25s ease;
}
.skill-pill:hover {
  color: white;
  border-color: transparent;
  transform: translateY(-1px);
}
.skill-pill:hover::before {
  opacity: 1;
}
.dark .skill-pill::before {
  background: linear-gradient(135deg, #064e3b, #0f766e, #065f46);
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
}

/* ===== TIMELINE ===== */
.timeline {
  position: relative;
  padding-left: 2rem;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 7px;
  top: 8px;
  bottom: 8px;
  width: 3px;
  background: linear-gradient(to bottom, var(--gradient-deep), var(--gradient-teal));
  transition: background 0.3s;
  border-radius: 2px;
}

.timeline-dot {
    position: absolute;
    left: -39px;
    top: 0px;
    width: 25px;
    height: 25px;
    border-radius: 50%;
    background: var(--primary);
    border: 6px solid var(--bg);
    box-shadow: 0 0 0 2px var(--primary);
    z-index: 1;
    animation: pulse-dot 2s ease-in-out infinite;
}


.timeline-item {
  position: relative;
  margin-bottom: 2rem;
  padding: 1rem 1rem 1rem 1.5rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  border-left: 3px solid var(--primary);
  transition: all 0.3s ease;
}
.timeline-item:last-child { margin-bottom: 0; }
.timeline-item:hover {
  transform: translateX(4px);
  box-shadow: var(--shadow-lg);
  border-left-color: var(--teal);
}
.timeline-date {
  display: inline-block;
  font-size: 0.75rem;
  color: white;
  font-weight: 700;
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  padding: 2px 12px;
  border-radius: 999px;
  margin-bottom: 8px;
}

/* ===== SKILL BAR ===== */
.skill-bar-track {
  height: 6px;
  background: var(--border);
  border-radius: 999px;
  overflow: hidden;
  transition: background 0.3s;
}
.skill-bar-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  transition: width 1.5s ease;
  width: 0;
}
.skill-bar-fill.animated { /* width set via JS */ }

/* ===== PROJECT ===== */
.project-filter-btn {
  padding: 6px 18px;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 600;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text);
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  font-family: inherit;
  position: relative;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
}
.project-filter-btn:hover { border-color: var(--primary); color: var(--primary); transform: translateY(-1px); }
.project-filter-btn.active {
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  border-color: transparent;
  color: white;
  box-shadow: 0 2px 10px rgba(20,184,166,0.3);
}
.project-enter-active, .project-leave-active { transition: all 0.2s ease; }
.project-enter-from { opacity: 0; transform: scale(0.95); }
.project-leave-to { opacity: 0; transform: scale(0.95); }

/* ===== ACHIEVEMENT ===== */
.achievement-card {
  background: linear-gradient(135deg, rgba(20,184,166,0.05), rgba(16,185,129,0.05));
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid var(--border);
  border-left: 3px solid var(--primary);
  border-radius: var(--radius);
  padding: 1.25rem 1.5rem;
  transition: all 0.3s;
}
.achievement-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateX(4px);
}

/* ===== CONTACT FORM ===== */
.contact-input {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-card);
  color: var(--text-heading);
  font-family: inherit;
  font-size: 0.85rem;
  transition: all 0.2s;
  outline: none;
}
.contact-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(20,184,166,0.12), var(--shadow-glow);
}
.contact-input::placeholder { color: var(--text-muted); }
.contact-input.error {
  border-color: #ef4444;
  box-shadow: 0 0 0 3px rgba(239,68,68,0.1);
  animation: shake 0.4s ease;
}
.contact-input.success {
  border-color: var(--accent-emerald);
  box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4px); }
  75% { transform: translateX(4px); }
}
textarea.contact-input { resize: vertical; min-height: 100px; }

/* ===== DARK MODE BUTTON ===== */
.theme-toggle {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  border: 1px solid var(--toggle-border);
  background: var(--toggle-bg);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  color: var(--text);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}
.theme-toggle:hover {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--toggle-bg);
}
.fab-toggle {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid var(--toggle-border);
  background: var(--toggle-bg);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: var(--text-muted);
  box-shadow: 0 4px 15px rgba(0,0,0,0.15);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}
.fab-toggle:hover {
  border-color: var(--primary);
  color: var(--primary);
}
.theme-toggle:hover {
  border-color: var(--primary);
  color: var(--primary);
}

/* ===== SCROLL TO TOP ===== */
.scroll-top {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: var(--primary);
  color: white;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  transition: all 0.3s;
  z-index: 30;
  opacity: 0;
  visibility: hidden;
}
.scroll-top.visible {
  opacity: 1;
  visibility: visible;
}
.scroll-top:hover {
  transform: translateY(-3px) scale(1.05);
  background: var(--primary-dark);
  box-shadow: 0 6px 20px rgba(20,184,166,0.4);
}
.scroll-top:active {
  transform: translateY(0) scale(0.95);
}

/* ===== REFERENCE CARD ===== */
.ref-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  transition: all 0.3s;
}
.ref-card:hover {
  border-color: var(--primary);
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}
.ref-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: 700;
  font-size: 1.1rem;
  flex-shrink: 0;
  transition: box-shadow 0.3s ease, transform 0.3s ease;
}
.ref-card:hover .ref-avatar {
  box-shadow: 0 0 0 4px rgba(20,184,166,0.15), 0 0 20px rgba(20,184,166,0.1);
  transform: scale(1.05);
}

/* ===== FOOTER ===== */
.footer {
  text-align: center;
  padding: 2rem 60px;
  border-top: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 0.85rem;
  transition: all 0.3s;
  position: relative;
}
.footer::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 10%;
  right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gradient-deep), var(--gradient-teal), transparent);
}
.footer a {
  color: var(--primary);
  transition: color 0.2s;
}
.footer a:hover {
  color: var(--teal);
}

/* ===== ANIMATIONS ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(-30px); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
@keyframes pulse-dot {
  0%, 100% { box-shadow: 0 0 0 2px var(--primary), 0 0 0 0 rgba(20,184,166,0.3); }
  50% { box-shadow: 0 0 0 2px var(--primary), 0 0 0 8px rgba(20,184,166,0); }
}
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
@keyframes ripple {
  to { transform: scale(4); opacity: 0; }
}
@keyframes glow-border {
  0%, 100% { border-color: rgba(20,184,166,0.3); }
  50% { border-color: rgba(16,185,129,0.3); }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-in {
  animation: fadeInUp 0.6s ease forwards;
}
.animate-in-d1 { animation-delay: 0.1s; }
.animate-in-d2 { animation-delay: 0.2s; }
.animate-in-d3 { animation-delay: 0.3s; }
.animate-in-d4 { animation-delay: 0.4s; }

/* ===== UTILITY ===== */
.gradient-text {
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradient-shift 4s ease infinite;
}
.gradient-bg {
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
}
.gradient-border {
  border: 1px solid transparent;
  background-clip: padding-box;
  position: relative;
}
.gradient-border::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

@keyframes gradient-shift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ===== TEXT SIZE UTILITIES (Tailwind-style) ===== */
.text-md { font-size: 1rem; line-height: 1.5rem; }
.text-lg { font-size: 1.125rem; }
.text-2xl { font-size: 1.5rem; }
.text-3xl { font-size: 1.875rem; }

/* ===== IMAGE PLACEHOLDER ===== */
.img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--border), var(--bg-card));
  border-radius: var(--radius);
  min-height: 160px;
  position: relative;
  overflow: hidden;
}
.img-placeholder::before {
  content: 'image';
  font-family: 'Material Icons';
  font-size: 48px;
  color: var(--text-muted);
  opacity: 0.4;
}
.img-placeholder::after {
  content: 'No screenshot available';
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 0.75rem;
  color: var(--text-muted);
  opacity: 0.6;
  white-space: nowrap;
}

/* ===== DARK MODE GLOW ===== */
.dark .skill-pill {
  background: rgba(45,212,191,0.15);
  color: #5eead4;
  border-color: rgba(45,212,191,0.3);
}
.dark .card-glass:hover {
  box-shadow: 0 8px 30px rgba(45,212,191,0.1), 0 0 0 1px rgba(45,212,191,0.06);
}
.dark .card-glass--glass:hover {
  background: rgba(26,35,50,0.8);
  box-shadow: var(--shadow-glow), var(--glass-shadow);
}
.dark .gradient-border-card {
  border: 1px solid transparent;
  background-clip: padding-box;
  position: relative;
}
.dark .gradient-border-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(135deg, rgba(20,184,166,0.3), rgba(16,185,129,0.3));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

/* ===== VIEW DETAILS BTN ===== */
.project-card-item {
  background: var(--bg-card);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
}
.project-card-item:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.project-cat-tag {
  background: rgba(20,184,166,0.08);
  color: var(--primary);
}
.project-title-link { color: var(--text-heading); }
.project-title-link:hover { color: var(--primary) !important; }

.hero-subtitle { font-size: 1.125rem; }
@media (max-width: 767px) { .hero-subtitle { font-size: 1rem; } }
@media (max-width: 359px) { .hero-subtitle { font-size: 0.9rem; } }

/* Responsive project detail */
@media (max-width: 767px) {
  [style*="font-size:2.2rem"] { font-size: 1.5rem !important; }
  [style*="font-size:1.1rem"] { font-size: 0.95rem !important; }
}
@media (max-width: 359px) {
  [style*="font-size:2.2rem"] { font-size: 1.25rem !important; }
  [style*="font-size:1.1rem"] { font-size: 0.85rem !important; }
}

.btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 16px;
  font-size: 0.85rem;
  font-weight: 600;
  border-radius: 999px;
  border: 1px solid var(--primary);
  color: var(--primary);
  background: transparent;
  transition: all 0.25s ease;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  z-index: 1;
}
.btn-outline::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  opacity: 0;
  z-index: -1;
  transition: opacity 0.25s ease;
}
.btn-outline:hover {
  color: white;
  border-color: transparent;
}
.btn-outline:hover::before {
  opacity: 1;
}
.dark .btn-outline::before {
  background: linear-gradient(135deg, #064e3b, #0f766e, #065f46);
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
}

/* ===== PROJECT CARD IMAGE HOVER ===== */
.project-card {
  transition: transform 0.4s ease, box-shadow 0.4s ease;
  position: relative;
  overflow: hidden;
}
.project-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 40%);
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
  z-index: 1;
}
.project-card:hover {
  transform: scale(1.01);
  box-shadow: var(--shadow-lg);
}
.project-card:hover::after {
  opacity: 1;
}
.project-card img {
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}
.project-card:hover img {
  transform: scale(1.05);
}

/* ===== FADE TRANSITION FOR PAGES ===== */
.fade-enter-active, .fade-leave-active {
  transition: all 0.35s ease;
}
.fade-enter-from {
  opacity: 0;
  transform: translateY(20px);
}
.fade-leave-to {
  opacity: 0;
  transform: translateY(-20px);
}

/* ===== LOADING SKELETON ===== */
.skeleton {
  background: linear-gradient(90deg, var(--border) 25%, var(--bg-card) 50%, var(--border) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease infinite;
  border-radius: var(--radius-sm);
}
.skeleton-text {
  height: 14px;
  margin-bottom: 8px;
  border-radius: 4px;
}
.skeleton-text:last-child { width: 60%; }
.skeleton-card {
  height: 200px;
  border-radius: var(--radius);
}

/* ===== BTN RIPPLE ===== */
.btn-ripple {
  position: relative;
  overflow: hidden;
}
.btn-ripple::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  transform: scale(0);
  opacity: 1;
  pointer-events: none;
}
.btn-ripple:active::after {
  animation: ripple 0.5s ease-out;
}

/* ===== SHIMMER BUTTON ===== */
.btn-shimmer {
  position: relative;
  overflow: hidden;
}
.btn-shimmer::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s;
}
.btn-shimmer:hover::before {
  left: 100%;
}

/* ===== TIMELINE UPDATES ===== */

/* ===== REFERENCE CARD TWEAKS ===== */

/* ===== OFFCANVAS ===== */
.offcanvas-enter-active { transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1); }
.offcanvas-leave-active { transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
.offcanvas-enter-from { transform: translateX(100%); }
.offcanvas-leave-to { transform: translateX(100%); }
.offcanvas-enter-active .ref-avatar,
.offcanvas-leave-active .ref-avatar { transition: none; }

/* ===== TYPEWRITER CURSOR ===== */
.typewriter-cursor {
  background: linear-gradient(135deg, var(--gradient-deep), var(--gradient-teal), var(--gradient-green));
  background-size: 200% 200%;
  animation: gradient-shift 4s ease infinite;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.typewriter-cursor::after {
  content: '|';
  animation: blink 0.7s step-end infinite;
  margin-left: 2px;
  color: var(--primary);
  font-weight: 300;
  -webkit-text-fill-color: var(--primary);
}
@keyframes blink {
  50% { opacity: 0; }
}

/* ===== PRINT ===== */
@media print {
  .sidebar { display: none !important; }
  .mobile-nav { display: none !important; }
  .main-content { margin-left: 0 !important; }
  .section { padding: 30px 20px !important; break-inside: avoid; }
  .hero-section { padding: 40px 20px !important; }
  .card-glass, .card-glass-alt, .achievement-card, .ref-card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
  .scroll-top, .theme-toggle, .project-filter-btn { display: none !important; }
  .footer { padding: 1rem 20px !important; }
  .dark { --bg: white !important; --text: #333 !important; --text-heading: #000 !important; --border: #ddd !important; --bg-card: #f9f9f9 !important; }
  .skill-bar-fill { width: 100% !important; }
  .timeline::before { display: none; }
  .timeline-dot { display: none; }
  .timeline { padding-left: 0; }
  .timeline-item { padding-left: 0; }
  html { scroll-behavior: initial; }
}

/* ===== RESPONSIVE ===== */

/* 1920px+ — Ultra-wide */
@media (min-width: 1920px) {
  .hero-section { padding: 120px 80px 100px; }
  .hero-title { font-size: 3rem; }
  .section { padding: 100px 80px; }
  .section-title { font-size: 2rem; }
  .footer { padding: 2.5rem 80px; }
}

/* 1440-1919px — Large desktop */
@media (min-width: 1440px) and (max-width: 1919px) {
  .hero-section { padding: 110px 70px 90px; }
  .hero-title { font-size: 2.8rem; }
  .section { padding: 90px 70px; }
  .section-title { font-size: 1.85rem; }
  .footer { padding: 2rem 70px; }
}

/* 1280-1439px — Default desktop (baseline — current CSS) */

/* 1024-1279px — Small desktop / tablet landscape */
@media (max-width: 1279px) {
  .hero-section { padding: 90px 40px 70px; }
  .hero-title { font-size: 2.2rem; }
  .section { padding: 70px 40px; }
  .section-title { font-size: 1.65rem; }
  .sidebar h2.text-xl { font-size: 1rem; }
  .sidebar p.text-lg { font-size: 0.9rem; }
  .sidebar .sidebar-scroll .font-medium { font-size: 0.8rem; }
  .sidebar .nav-link span { font-size: 0.85rem; }
  .footer { padding: 1.8rem 40px; }
  [style*="padding:0 60px"] { padding-left: 40px !important; padding-right: 40px !important; }
}

/* 768-1023px — Tablet portrait */
@media (max-width: 1023px) {
  .sidebar { display: none !important; }
  .mobile-nav { display: block; }
  .main-content { margin-left: 0; }
  .hero-section { padding: 90px 24px 60px; }
  .hero-title { font-size: 2rem; }
  .hero-stats { gap: 1.5rem; }
  .section { padding: 60px 24px; }
  .section-title { font-size: 1.6rem; }
  .text-lg { font-size: 1rem; }
  .text-md { font-size: 1rem; }
  .text-xl { font-size: 1.1rem; }
  .text-2xl { font-size: 1.3rem; }
  .text-3xl { font-size: 1.5rem; }
  .mobile-nav .text-lg { font-size: 1rem; }
  .footer { padding: 1.5rem 24px; }
  .skill-pill { min-height: 40px; display: inline-flex; align-items: center; font-size: 0.85rem; padding: 6px 16px; }
  .project-filter-btn { min-height: 44px; }
  [style*="padding:0 60px"] { padding-left: 24px !important; padding-right: 24px !important; }
  [style*="height:400px"] { height: 280px !important; }
  [style*="height:192px"] { height: 140px !important; }
}

/* 360-767px — Phone */
@media (max-width: 767px) {
  .hero-title { font-size: 1.5rem; }
  .hero-stat-value { font-size: 1.2rem; }
  .hero-section { padding: 80px 16px 50px; }
  .hero-stats { gap: 1rem; justify-content: center; }
  .section { padding: 40px 16px; }
  .section-title { font-size: 1.35rem; }
  .text-lg { font-size: 0.95rem; }
  .text-md { font-size: 0.9rem; }
  .text-xl { font-size: 1.05rem; }
  .text-2xl { font-size: 1.2rem; }
  .text-3xl { font-size: 1.4rem; }
  .mobile-nav .text-lg { font-size: 0.95rem; }
  .card-glass, .card-glass-alt { padding: 1.2rem; }
  .card-glass p, .card-glass li, .card-glass div:not([class*="flex"]):not([class*="grid"]):not(.skill-pill), .card-glass span:not(.skill-pill) { font-size: 0.9rem; }
  .timeline-item .text-lg, .contact-info .text-lg { font-size: 0.9rem !important; }
  .ref-card { padding: 1rem; }
  .skill-pill { font-size: 0.8rem; padding: 6px 14px; }
  .timeline-item p, .timeline-item li { font-size: 0.85rem; }
  .footer { padding: 1rem 16px; }
  [style*="padding:0 60px"] { padding-left: 8px !important; padding-right: 8px !important; }
  [style*="border-radius:0 0 40px 40px"] { border-radius: 0 0 20px 20px !important; }
  [style*="height:400px"] { height: 200px !important; }
  [style*="height:192px"] { height: 120px !important; }
  .img-placeholder::after { white-space: normal; font-size: 0.65rem; }
  .hero-btn { padding: 0.6rem 1rem !important; font-size: 0.85rem !important; }
  h3.text-lg, h4.text-lg { font-size: 1rem; }
}

/* 320-359px — Small phone */
@media (max-width: 359px) {
  .hero-section { padding: 75px 12px 40px; }
  .hero-title { font-size: 1.25rem; }
  .hero-stat-value { font-size: 1rem; }
  .section { padding: 30px 12px; }
  .section-title { font-size: 1.15rem; }
  .text-lg { font-size: 0.85rem; }
  .text-md { font-size: 0.85rem; }
  .text-xl { font-size: 0.95rem; }
  .text-2xl { font-size: 1.05rem; }
  .text-3xl { font-size: 1.2rem; }
  .card-glass, .card-glass-alt { padding: 0.9rem; }
  .card-glass p, .card-glass li, .card-glass div:not([class*="flex"]):not([class*="grid"]):not(.skill-pill), .card-glass span:not(.skill-pill) { font-size: 0.85rem; }
  .skill-pill { font-size: 0.75rem; padding: 4px 10px; margin: 2px; }
  .footer { padding: 0.8rem 12px; font-size: 0.75rem; }
  [style*="padding:0 60px"] { padding-left: 8px !important; padding-right: 8px !important; }
  [style*="height:400px"] { height: 160px !important; }
  [style*="height:192px"] { height: 100px !important; }
  .hero-stats { gap: 0.6rem; }
}



